{
  "name": "ripppl",
  "version": "0.1.2",
  "description": "Ripple displacement using WebGL over the DOM",
  "keywords": [
    "ripple",
    "webgl",
    "dom",
    "effect",
    "animation",
    "canvas"
  ],
  "license": "MIT",
  "author": "Arman Luthra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arman-Luthra/ripppl.git"
  },
  "bugs": {
    "url": "https://github.com/Arman-Luthra/ripppl/issues"
  },
  "homepage": "https://github.com/Arman-Luthra/ripppl#readme",
  "type": "module",
  "main": "./dist/ripppl.js",
  "module": "./dist/ripppl.js",
  "types": "./dist/ripppl.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ripppl.d.ts",
      "import": "./dist/ripppl.js",
      "default": "./dist/ripppl.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "culori": "^4.0.2",
    "gsap": "^3.14.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "dom-to-image-more": "^3.7.2",
    "html2canvas": "^1.4.1"
  }
}
